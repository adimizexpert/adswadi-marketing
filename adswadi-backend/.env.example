# PostgreSQL connection string (Render Postgres dashboard → Connect → Internal or External URL)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# Set to "true" if your host requires SSL (Render external URL, most cloud Postgres)
DATABASE_SSL=true

JWT_SECRET=some-long-random-secret-change-this
FRONTEND_URL=https://your-app.vercel.app
PORT=3001
